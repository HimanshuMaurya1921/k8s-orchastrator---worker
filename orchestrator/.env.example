# ─── Runtime Mode ─────────────────────────────────────────────────────────────
# 'local' (Docker) or 'gke' (Kubernetes)
RUNTIME=local

# ─── Network ──────────────────────────────────────────────────────────────────
# The port the Orchestrator itself listens on
WORKER_PORT=3001

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Shared secret for communication with workers. Use a strong random string.
WORKER_AUTH_TOKEN=local-dev-token

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local: localhost
# K8s:   redis.preview.svc.cluster.local
REDIS_HOST=redis.preview.svc.cluster.local
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Worker Configuration ─────────────────────────────────────────────────────
# Image to pull for preview sandboxes
WORKER_IMAGE=preview-worker:local

# ─── Performance & Lifecycle ──────────────────────────────────────────────────
# Max time to wait for a pod to be ready (milliseconds)
BOOT_TIMEOUT_MS=90000

# Max pods allowed in the cluster (Safety limit)
MAX_PREVIEW_PODS=40

# How long a session remains active in Redis (seconds)
SESSION_TTL_SECONDS=1800

# Grace period before deleting a session after a user leaves (seconds)
TERMINATION_GRACE_PERIOD_SECONDS=30

# How often the janitor checks for expired grace periods (milliseconds)
JANITOR_PULSE_INTERVAL_MS=10000
