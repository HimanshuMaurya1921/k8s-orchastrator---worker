# ─── Server Configuration ─────────────────────────────────────────────────────
# Internal worker API port
PORT=3000

# Next.js / Vite development server port
NEXT_PORT=3001

# ─── Auth ─────────────────────────────────────────────────────────────────────
# MUST match the Orchestrator's WORKER_AUTH_TOKEN
AUTH_TOKEN=local-dev-token

# ─── Workspace ────────────────────────────────────────────────────────────────
# Where code is injected. In K8s, this is usually an emptyDir volume.
WORKSPACE=/workspace

# ─── Identity ─────────────────────────────────────────────────────────────────
# Set by K8s Downward API (metadata.name)
POD_NAME=local-worker

# ─── Performance ──────────────────────────────────────────────────────────────
# Node.js memory tuning (e.g. 80% of K8s limit)
NODE_OPTIONS="--max-old-space-size=800 --expose-gc"
